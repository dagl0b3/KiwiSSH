### KiwiSSH - Main Configuration
##
## To see a list of all available paramaters and their descriptions, please refer to the README.md or the Pydantic models in /backend/app/core/config.py.
##
### WARNING: Rename this file to "kiwissh.yaml" and edit the values to suit your environment. Do not edit this example file directly!

### Application settings
app:
  debug: false
  threads: 20
  timeout: 30
  retry: 2
  schedule:
    cron: "0 2 * * *" # Daily at 2 AM
  api:
    host: "0.0.0.0" # Should be set to 0.0.0.0 when running in Docker to be accessible from outside the container

### Application database (PostgreSQL only)
## This database stores KiwiSSH-owned data (backup job logs, favorites, etc.)
## The database itself and the user must already exist, the required tables will be created automatically.
application_database:
  host: "192.168.15.25"
  port: 5432
  database: "kiwissh"
  username: "kiwissh_user"
  password: "kiwissh-user-password"

### Notification settings (optional, disabled by default)
## Read about the configuration options in the README.md
notifications:
  enabled: true
  trigger: "always"
  type:
    smtp:
      host: "smtp.example.com"
      sender: "kiwissh@example.com"
      recipients:
        - "admin@example.com"

### Device sources
## Load from a CSV file, an Ansible inventory YAML, PostgreSQL or an HTTP endpoint. Exactly one source is required.
## Required fields per device: group, device_name, ip_address, enabled
## Paths may be absolute, or relative to the config directory.
sources:
  # file: "/config/sources/devices.csv"
  # ansible: "/config/sources/inventory.yaml"
  postgres:
      host: "172.16.147.56"
      port: 5432
      database: "existing_inventory_db"
      table: "prod_devices"
      username: "kiwissh"
      password: "strongpassword"
  # http:
  #     url: "http://10.11.12.13/api/devices"
  #     headers:
  #       X-Auth-Token: "1d73fabef8a44f5714b585cf0xxxxx"
  #     map:            # maps KiwiSSH field -> JSON response field (defaults shown)
  #       device_name: hostname
  #       ip_address: ip
  #     default_group: "core-switches"  # used when the response has no group field

### Global git backup repository settings
## Local git storage is always active and stores one repository per group under local_path.
## DO NOT delete the "backups" folder ever unless you want to lose all your local git repositories and their history.
## Paths may be absolute, or relative to the config directory.
git:
  local_path: "/config/backups"
  ### Optional global remote git location for groups without overrides.
  ### If this block is configured, git.remote.url is required.
  # remote:
  #   url: "ssh://git@github.com:<YOUR_ORGANIZATION_HERE>/{group}.git" # Keep {group} placeholder for dynamic repo names based on group

### Groups configuration
## Priority for device configuration (default to most specific): app < groups < nodes
## KiwiSSH closes shell sessions automatically after backup command phases, you don't need to explicitly add "exit" or "logout" but you can.
groups:
  <your-group-name-here>:
    username: "admin"
    password: "password"
    ssh_profile: "modern"
    vendor: "cisco_ios"
    git:
      remote:
        url: "ssh://git@gitea/customer-aaa/switches.git"
    jumphost:
      username: "jumphost-user"
      hostname: "my.jumphost.com"
      ssh_profile: "legacy-jumphost"
  
  <another-group-name>:
    username: "admin"
    password: "password"
    protocol: "telnet" # Optional override
    vendor: "fortinet_fortigate"
    git:
      remote:
        url: "ssh://git@<domain>/customer-bbb/firewalls.git"

### Per-node overrides
## Nodes can override: ssh_profile, protocol, port, vendor, timeout, retry, username, password, ssh_key_file, jumphost, schedule, git.commit_message_template
## Group CANNOT be overridden - change it in the source instead
## Remove this section if no overrides needed
nodes:
  <device-name-here>:
    retry: 5
    port: 2222
    ssh_key_file: "/home/kiwissh/.ssh/key_for_device"
    jumphost:
      hostname: "10.20.30.41"
      username: "node-jump-user"
      # password: "node-jump-password"
      ssh_key_file: "/home/kiwissh/.ssh/key_for_jumphost"
